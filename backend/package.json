{
  "name": "fitcoach-ai-backend",
  "version": "1.0.0",
  "description": "FitCoach AI backend — Lambda + Amazon Bedrock Nova",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "local": "sam local start-api --env-vars env.local.json",
    "deploy": "sam build && sam deploy --guided"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.600.0",
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.140",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.4.5"
  }
}
